# ── Telegram ────────────────────────────────────────────────────────────────
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot (everyone listed
# also receives reminders). Send /start to your bot to discover your ID.
TELEGRAM_ALLOWED_USER_IDS=

# ── Vikunja ─────────────────────────────────────────────────────────────────
# URL the bot uses to reach Vikunja. Inside docker-compose this is the
# service name; point it at your own instance if you already run Vikunja.
VIKUNJA_URL=http://vikunja:3456

# API token: Vikunja → Settings → API Tokens. Needs permissions on
# tasks (read/create/update/delete) and projects (read).
VIKUNJA_API_TOKEN=

# Project tasks land in when no #project is given (1 = your first project).
DEFAULT_PROJECT_ID=1

# Secret Vikunja signs login sessions with: generate with `openssl rand -hex 32`.
VIKUNJA_SECRET=

# Public URL of the Vikunja web UI (used by Vikunja itself and in bot links).
VIKUNJA_PUBLIC_URL=http://localhost:3456/

# ── Behaviour ───────────────────────────────────────────────────────────────
# IANA timezone for parsing ("tomorrow 6pm") and displaying dates.
TIMEZONE=Europe/Bucharest

# How often the bot checks Vikunja for due reminders, in seconds.
REMINDER_POLL_SECONDS=60

# ── Optional: LLM parsing of free-form messages ─────────────────────────────
# Any OpenAI-compatible endpoint: Ollama (http://host:11434/v1), llama.cpp,
# OpenRouter, OpenAI, ... Leave LLM_BASE_URL empty to use the built-in
# date parser instead (no AI required).
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
